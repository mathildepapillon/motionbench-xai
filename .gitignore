# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
carepd/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# WandB
wandb/

# Model checkpoints (regenerate locally, never commit — incl. upstream-derived
# CARE-PD weights which are CC BY-NC-4.0 and not redistributable)
motionbench/classifiers/checkpoints/**/*.pt
motionbench/classifiers/checkpoints/**/*.pth
motionbench/classifiers/checkpoints/**/*.pth.tr
motionbench/classifiers/checkpoints/**/*.ckpt
motionbench/classifiers/checkpoints/**/*.npz
motionbench/classifiers/checkpoints/care_pd/
motionbench/classifiers/checkpoints/synthetic/
motionbench/classifiers/checkpoints/real/
!motionbench/classifiers/checkpoints/.gitkeep
!motionbench/classifiers/checkpoints/synthetic/.gitkeep
!motionbench/classifiers/checkpoints/real/.gitkeep

# Results (generated, don't commit raw results) — keep .gitkeep markers only
results/*
!results/.gitkeep
!results/synthetic/.gitkeep
!results/care_pd/.gitkeep

# Hydra outputs
outputs/
multirun/
.hydra_outputs/

# Data (too large to commit) — raw top-level data dirs only
/data/
# Allow source-code under motionbench/data/
!motionbench/data/

# OS
.DS_Store
Thumbs.db

# Development scratch (internal coordination docs, archived experiments)
.dev/

# Paper sources and build artifacts (never committed; benchmark repo only)
paper/

# Paper-generation scripts (paper-author-only utilities)
scripts/generate_paper_tables.py
scripts/generate_paper_figures.py
scripts/generate_fig_real_all.py
scripts/regenerate_paper.sh
scripts/per_axis_evidence.py
scripts/cgfs_table.py
scripts/results_to_markdown.py

# Run logs (large)
logs/
results/*/*.log
results/*.log

# Misc accidental shell artifacts (e.g. `pip install foo>=0.4.0` without quoting)
=*
